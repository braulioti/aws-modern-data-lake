# Example .env file for the project.
# Copy to .env and fill in your values.

# URL or host of the DATASUS FTP
FTP_DATASUS=ftp://ftp.datasus.gov.br

# Temporary folder path for downloads
TEMP_DOWNLOAD_PATH=../tmp

# Temporary folder path for donwloaded files
TEMP_DBC_PATH=../tmp/dbc
TEMP_DBF_PATH=../tmp/dbf

# Temporary folder path for converted CSV files
TEMP_CSV_PATH=../tmp/csv

# Start period (inclusive): year and month
START_YEAR=2023
START_MONTH=1

# End period (inclusive): year and month
END_YEAR=2023
END_MONTH=10

# Brazilian state codes (UF), comma-separated
STATES=SP,RJ,MG

# AWS S3 bucket name for the data lake
AWS_S3_BUCKET=datalake-bucket
